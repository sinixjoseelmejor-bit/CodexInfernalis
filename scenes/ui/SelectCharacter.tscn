[sub_resource type="Shader" id="Shader_vignette"]
code = "shader_type canvas_item;
uniform float strength : hint_range(0.0, 3.0) = 0.5;
void fragment() {
    vec2 uv = UV * 2.0 - 1.0;
    uv.x *= 0.75;
    float v = clamp(1.0 - dot(uv, uv) * strength, 0.0, 1.0);
    COLOR = vec4(0.0, 0.0, 0.0, 1.0 - v);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vignette"]
shader = SubResource("Shader_vignette")

